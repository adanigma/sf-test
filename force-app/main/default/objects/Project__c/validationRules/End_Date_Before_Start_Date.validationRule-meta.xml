<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>End_Date_Before_Start_Date</fullName>
    <active>true</active>
    <description>Prevents End Date from being set to a date before Start Date.</description>
    <errorConditionFormula>AND(
    NOT(ISBLANK(End_Date__c)),
    NOT(ISBLANK(Start_Date__c)),
    End_Date__c &lt; Start_Date__c
)</errorConditionFormula>
    <errorDisplayField>End_Date__c</errorDisplayField>
    <errorMessage>End Date cannot be before Start Date.</errorMessage>
</ValidationRule>
